# ──────────────────────────────
#  AI写作平台 — 本地开发环境变量
# ──────────────────────────────
#  复制此文件为 .env 并修改

# ── AI 模型 API Key（至少设置一个才能使用 AI 生成） ──
# 通用 Key（所有模型共用，推荐）
LLM_API_KEY=sk-your-key-here
# 或分别指定不同模型
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com
# CLAUDE_API_KEY=sk-ant-xxx
# CLAUDE_BASE_URL=https://api.anthropic.com
# GLM_API_KEY=xxx
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
# QWEN_API_KEY=sk-xxx
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# CUSTOM_API_KEY=sk-xxx
# CUSTOM_BASE_URL=https://your-custom-api.com/v1/chat/completions

# ── 服务端口 ──
SERVER_PORT=3000
DATABASE_PATH=./data/novelai.db

# ── ChromaDB ──
CHROMADB_URL=http://localhost:8000
CHROMADB_PORT=8000

# ── 日志 (error | warn | info | debug | verbose) ──
# debug: 错误+警告+信息+调试（默认，不输出TRACE）
# verbose/trace: 最详细级别，包含所有TRACE信息
LOG_LEVEL=debug
NODE_ENV=development
TZ=Asia/Shanghai
